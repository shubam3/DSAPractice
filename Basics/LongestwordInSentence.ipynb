   "source": [
    "def longest_word(sentence):\n",
    " \n",
    "  \n",
    "  words = sentence.split()\n",
    "  print(words)\n",
    "  longest = \"\"\n",
    "  \n",
    "  for word in words:\n",
    "    if len(word) >= len(longest):\n",
    "       longest = word\n",
    "\n",
    "  return longest   \n",
    "\n",
    "longest_word(\"hello Shubam\")\n",
    "  "
   ]
  }
